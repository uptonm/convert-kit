# Optional public site URL for sitemap / metadata
# Local: http://localhost:3000
# Production: https://convert.uptonm.dev
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Currency converter uses Frankfurter for FX *rates* only (supplementary data).
# No API key required. No file-conversion SaaS keys — conversions are owned in-browser.

# Fleet Clerk gate (production-only enforcement). Use pk_test/sk_test locally.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=https://uptonm.dev/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=https://uptonm.dev/sign-up
GATES_APP_ID=convert-kit
# Production only — omit locally so the gate stays off outside Vercel production.
# GATES_ORG_ID=
